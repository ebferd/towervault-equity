# ─────────────────────────────────────────────────────────────
#  NexVest — files that must NEVER be overwritten on the server
#  (they live only on the live server and hold real data/config)
# ─────────────────────────────────────────────────────────────
/.env

/uploads/*
!/uploads/.gitkeep

/storage/logs/*
!/storage/logs/.gitkeep

/storage/tmp/*
!/storage/tmp/.gitkeep

/storage/sessions/*
!/storage/sessions/.htaccess

# dev-only helper, not needed on server
/storage/make_zip.php
/preview-portfolio.html

# NOTE: vendor/ (Composer libraries) IS committed to this repo on purpose,
# so deployment needs no Composer/SSH — a plain git pull brings everything.

# mPDF bundles ~88MB of language fonts; this app only renders with DejaVu.
# Ship the DejaVu family only — keeps the repo small and deploys fast.
vendor/mpdf/mpdf/ttfonts/*
!vendor/mpdf/mpdf/ttfonts/DejaVu*

# ── Dev / OS junk ──
*.bak
*.tmp
*.log
.DS_Store
Thumbs.db
_cert*.html
_cert*.pdf
/_certpreview/
